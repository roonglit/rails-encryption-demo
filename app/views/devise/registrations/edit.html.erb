<div class="space-y-2 text-center">
  <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Account settings</h2>
  <p class="text-sm text-slate-500">Update your email or change your password.</p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-1.5">
    <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
    <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          class: "block w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p class="text-xs text-amber-600">Pending confirmation for <%= resource.unconfirmed_email %></p>
    <% end %>
  </div>

  <div class="space-y-1.5">
    <div class="flex items-baseline justify-between">
      <%= f.label :password, "New password", class: "block text-sm font-medium text-slate-700" %>
      <span class="text-xs text-slate-400">Leave blank to keep current</span>
    </div>
    <%= f.password_field :password,
          autocomplete: "new-password",
          class: "block w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    <% if @minimum_password_length %>
      <p class="text-xs text-slate-400"><%= @minimum_password_length %>+ characters</p>
    <% end %>
  </div>

  <div class="space-y-1.5">
    <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-slate-700" %>
    <%= f.password_field :password_confirmation,
          autocomplete: "new-password",
          class: "block w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
  </div>

  <div class="space-y-1.5">
    <%= f.label :current_password, class: "block text-sm font-medium text-slate-700" %>
    <%= f.password_field :current_password,
          autocomplete: "current-password",
          class: "block w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    <p class="text-xs text-slate-400">Required to confirm your changes.</p>
  </div>

  <%= f.submit "Save changes",
        class: "w-full cursor-pointer rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2" %>
<% end %>

<div class="mt-8 rounded-xl border border-rose-200 bg-rose-50/60 p-4">
  <h3 class="text-sm font-semibold text-rose-900">Danger zone</h3>
  <p class="mt-1 text-xs text-rose-700">Cancelling your account is permanent and cannot be undone.</p>
  <%= button_to "Cancel my account",
        registration_path(resource_name),
        method: :delete,
        data: { turbo_confirm: "Are you sure? This cannot be undone." },
        class: "mt-3 inline-flex cursor-pointer items-center rounded-lg border border-rose-300 bg-white px-3 py-1.5 text-xs font-medium text-rose-700 transition hover:bg-rose-100" %>
</div>

<p class="mt-6 text-center text-sm">
  <%= link_to "Back", :back, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
</p>
